           dist=6: (0,6),(1,5),(2,4),(3,3)blocked,(4,2),(5,1),(6,0)
           dist=7: (0,7),(1,6),(2,5),(3,4),(4,3),(5,2),(6,1),(7,0)
           dist=8: (1,7),(2,6),(3,5),(4,4),(5,3),(6,2),(7,1)
           dist=9: (2,7),(3,6),(4,5),(5,4),(6,3),(7,2)
           dist=10: (3,7),(4,6),(5,5),(6,4),(7,3)
           dist=11: (4,7),(5,6)=GOAL ✓,(6,5),(7,4)
